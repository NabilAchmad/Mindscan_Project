{
  "expo": {
    "name": "frontend",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindscan.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MindScan membutuhkan akses kamera untuk mendeteksi ekspresi wajah Anda."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.mindscan.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "MindScan membutuhkan akses kamera untuk mendeteksi ekspresi wajah Anda secara lokal."
        }
      ],
      "react-native-fast-tflite"
    ],
    "extra": {
      "eas": {
        "projectId": "e9a1b6d3-eacc-4a4f-a666-c9f66c7b81c3"
      }
    }
  }
}
